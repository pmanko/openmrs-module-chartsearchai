<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
		"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
		"http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="org.openmrs.module.chartsearchai.model">
	<class name="ChartEmbedding" table="chartsearchai_embedding">
		<id name="embeddingId" type="int" column="embedding_id">
			<generator class="native"/>
		</id>
		<many-to-one name="patient" class="org.openmrs.Patient" column="patient_id" not-null="true"/>
		<property name="resourceType" type="string" column="resource_type" not-null="true" length="50"/>
		<property name="resourceUuid" type="string" column="resource_uuid" not-null="true" length="38"/>
		<property name="textContent" type="text" column="text_content" not-null="true"/>
		<property name="embedding" type="binary" column="embedding" not-null="true" length="16777215"/>
		<property name="dateCreated" type="timestamp" column="date_created" not-null="true"/>
	</class>
</hibernate-mapping>
