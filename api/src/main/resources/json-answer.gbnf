root   ::= "{" ws "\"answer\"" ws ":" ws string ws "," ws "\"citations\"" ws ":" ws citations ws "}"
string ::= "\"" chars "\""
chars  ::= char*
char   ::= [^"\\\n\r] | "\\" escape
escape ::= ["\\/bfnrt] | "u" hex hex hex hex
hex    ::= [0-9a-fA-F]
citations ::= "[]" | "[" ws number (ws "," ws number)* ws "]"
number ::= [0-9]+
ws     ::= [ \t]*
