{
  "dataset": "absent-data-detection-v1",
  "description": "Tests that the system correctly detects when patient data is absent and names what is missing",
  "cases": [
    {
      "id": "absent-cancer",
      "question": "Does the patient have cancer?",
      "expectedAbsent": true,
      "expectedAnswerContains": ["cancer"],
      "expectedAnswerNotContains": ["CD4", "tuberculosis"],
      "tags": ["absent"]
    },
    {
