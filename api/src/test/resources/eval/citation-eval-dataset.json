{
  "dataset": "citation-accuracy-v1",
  "description": "Tests that citation extraction correctly parses LLM JSON output and maps to record references",
  "records": [
    { "index": 1, "resourceType": "order", "resourceId": 101, "text": "Drug order: Azithromycin" },
    { "index": 2, "resourceType": "order", "resourceId": 102, "text": "Drug order: Azithromycin (stopped)" },
    { "index": 3, "resourceType": "program", "resourceId": 301, "text": "Program: PMTCT" },
    { "index": 4, "resourceType": "obs", "resourceId": 401, "text": "Immunization history" },
    { "index": 5, "resourceType": "allergy", "resourceId": 501, "text": "Allergy: Beef" },
    { "index": 6, "resourceType": "obs", "resourceId": 601, "text": "Method of family planning: Condoms" },
    { "index": 7, "resourceType": "obs", "resourceId": 701, "text": "Method of family planning: Diaphragm" },
    { "index": 8, "resourceType": "condition", "resourceId": 801, "text": "Condition: Tuberculosis. Status: ACTIVE" },
    { "index": 9, "resourceType": "obs", "resourceId": 901, "text": "CD4 Count: 988.0" },
    { "index": 10, "resourceType": "obs", "resourceId": 1001, "text": "CD4 Count: 1191.0" }
  ],
  "cases": [
    {
      "id": "citation-correct-single",
      "question": "Does the patient have tuberculosis?",
      "simulatedLlmResponse": "{\"answer\": \"Yes, the patient has Tuberculosis with an ACTIVE status [8].\", \"citations\": [8]}",
      "expectedRecordIndices": [8],
      "tags": ["citation", "exact"]
    },
    {
      "id": "citation-correct-multiple",
      "question": "What are the CD4 counts?",
      "simulatedLlmResponse": "{\"answer\": \"The CD4 counts are 988.0 [9] and 1191.0 [10].\", \"citations\": [9, 10]}",
      "expectedRecordIndices": [9, 10],
      "tags": ["citation", "exact"]
    },
    {
      "id": "citation-hallucinated-extra",
      "question": "What are the CD4 counts?",
      "simulatedLlmResponse": "{\"answer\": \"The CD4 counts are 988.0 [9] and 1191.0 [10].\", \"citations\": [9, 10, 3]}",
      "simulatedCitations": [9, 10, 3],
      "expectedRecordIndices": [9, 10],
      "tags": ["citation", "hallucination"]
    },
    {
      "id": "citation-missing",
      "question": "Does the patient have tuberculosis?",
      "simulatedLlmResponse": "{\"answer\": \"Yes, the patient has Tuberculosis.\", \"citations\": []}",
